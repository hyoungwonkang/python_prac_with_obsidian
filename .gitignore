# Claude Code — local-only settings (per machine/user)
.claude/settings.local.json

# OMC runtime state (Claude Code)
.omc/

# Obsidian — settings는 공유, 휘발성 상태/캐시는 제외
.obsidian/workspace*
.obsidian/cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables / secrets
.env
.env.*
!.env.example

# IDE / editor
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Node / Vercel (todo-app 배포 대비)
node_modules/
.next/
.vercel/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.vercel

# Notion 동기 — 캐시/로그만 제외 (스크립트·config는 git 포함, 토큰은 vault 밖)
.notion-sync/.cache/

# 실습 중 다운로드되는 데이터셋 (tokenization.py가 재다운로드 — 코드만 git 추적)
