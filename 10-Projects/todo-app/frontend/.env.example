# 백엔드 API 베이스 URL.
# 클라이언트 컴포넌트에도 노출되므로 NEXT_PUBLIC_ 접두사 필수.
#
# 로컬 개발 (기본값과 동일하므로 .env.local 없이도 동작):
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#
# 배포 (Phase 5에서 실제 frontend Vercel 프로젝트에 설정):
#   NEXT_PUBLIC_API_BASE_URL=https://python-prac-with-obsidian.vercel.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
