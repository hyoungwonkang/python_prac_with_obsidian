# 로컬 SQLite (기본값)
# DATABASE_URL=sqlite+aiosqlite:///./todo.db

# Supabase Postgres (pooler, IPv4)
DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# CORS 허용 origin (쉼표 구분). 기본값: http://localhost:3000
# 배포 환경에서는 실제 프론트엔드 URL로 교체. 예:
# CORS_ORIGINS=http://localhost:3000,https://todo-app-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000
